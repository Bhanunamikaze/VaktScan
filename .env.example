# VaktScan — API credentials
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# Shodan API key (for passive_intel module)
# Get yours at: https://account.shodan.io/
SHODAN_API_KEY=

# Censys API credentials (for passive_intel module)
# Get yours at: https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# Google Custom Search API (for google-dork subcommand)
# Create at: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=
# Custom Search Engine ID (cx) — create at: https://cse.google.com/
GOOGLE_CX=
